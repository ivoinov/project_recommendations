DATABASE_URL=postgresql://user:password@localhost/recommendations
SECRET_KEY=<generate-your-own-secret-key>
ACCESS_TOKEN_EXPIRE_MINUTES=30
CELERY_BROKER_URL=redis://localhost:6379/0
ALGORITHM=HS256

# Environment: development, staging, or production
ENVIRONMENT=development

# For production CORS - set your actual domain
ALLOWED_ORIGIN=https://yourdomain.com

# For Docker Compose
DB_PASSWORD=<set-strong-password>
DB_USER=recommendations_user